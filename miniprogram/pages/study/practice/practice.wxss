/* pages/study/practice/practice.wxss */
.container {
  min-height: 100vh;
  background-color: #f8f4e8;
  padding-bottom: 40rpx;
  display: block;
  width: 100%;
  max-width: 100%;
  box-sizing: border-box;
}

/* 页面头部 */
.page-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 30rpx;
  background: linear-gradient(135deg, #8B4513 0%, #A0522D 100%);
}

.exam-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
}

.question-count {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  background: rgba(255, 255, 255, 0.2);
  padding: 8rpx 20rpx;
  border-radius: 30rpx;
}

/* 章节选择 */
.chapter-section {
  padding: 20rpx 10rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #8B4513;
  margin-bottom: 20rpx;
  padding-left: 15rpx;
  border-left: 6rpx solid #CD853F;
}

.chapter-list {
  background-color: #fff;
  border-radius: 15rpx;
  overflow: hidden;
  border: 2rpx solid #D2B48C;
}

.chapter-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.chapter-item:last-child {
  border-bottom: none;
}

.chapter-info {
  flex: 1;
}

.chapter-name {
  font-size: 30rpx;
  color: #333;
  margin-bottom: 8rpx;
}

.chapter-count {
  font-size: 24rpx;
  color: #666;
}

.chapter-arrow {
  font-size: 32rpx;
  color: #CD853F;
}

/* 练习模式 */
.practice-section {
  padding: 20rpx 10rpx;
}

.progress-bar {
  height: 15rpx;
  background-color: #f0f0f0;
  border-radius: 8rpx;
  overflow: hidden;
  border: 2rpx solid #D2B48C;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #CD853F 0%, #8B4513 100%);
  transition: width 0.3s ease;
}

.progress-text {
  text-align: center;
  font-size: 24rpx;
  color: #666;
  margin-top: 10rpx;
}

.question-card {
  background-color: #fff;
  border-radius: 15rpx;
  padding: 30rpx;
  margin-top: 20rpx;
  border: 2rpx solid #D2B48C;
}

.question-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.question-type {
  font-size: 24rpx;
  color: #fff;
  background: linear-gradient(135deg, #8B4513 0%, #A0522D 100%);
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
}

.question-year {
  font-size: 24rpx;
  color: #666;
}

.question-content {
  font-size: 32rpx;
  color: #333;
  line-height: 1.6;
  margin-bottom: 30rpx;
}

/* 选项 */
.options-list {
  margin-bottom: 30rpx;
}

.option-item {
  display: flex;
  align-items: flex-start;
  padding: 24rpx;
  border: 2rpx solid #D2B48C;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
  transition: all 0.2s ease;
}

.option-item.selected {
  border-color: #8B4513;
  background-color: #FFF8F0;
}

.option-item.correct {
  border-color: #4CAF50;
  background-color: #e8f5e9;
}

.option-item.wrong {
  border-color: #f44336;
  background-color: #ffebee;
}

.option-key {
  width: 48rpx;
  height: 48rpx;
  line-height: 48rpx;
  text-align: center;
  background-color: #f0f0f0;
  border-radius: 50%;
  font-size: 26rpx;
  font-weight: bold;
  color: #666;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.option-item.selected .option-key {
  background-color: #8B4513;
  color: #fff;
}

.option-item.correct .option-key {
  background-color: #4CAF50;
  color: #fff;
}

.option-item.wrong .option-key {
  background-color: #f44336;
  color: #fff;
}

.option-content {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  line-height: 1.5;
}

.option-icon {
  font-size: 32rpx;
  margin-left: 16rpx;
}

.correct-icon {
  color: #4CAF50;
}

.wrong-icon {
  color: #f44336;
}

/* 答案和解析 */
.answer-section {
  background-color: #faf8f5;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 30rpx;
  border: 1rpx solid #D2B48C;
}

.answer-box {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.answer-label {
  font-size: 26rpx;
  color: #666;
  margin-right: 16rpx;
}

.answer-value {
  font-size: 32rpx;
  font-weight: bold;
  color: #8B4513;
}

.analysis-box {
  border-top: 2rpx solid #D2B48C;
  padding-top: 20rpx;
}

.analysis-label {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.analysis-content {
  font-size: 28rpx;
  color: #555;
  line-height: 1.6;
}

/* 操作按钮 */
.action-buttons {
  display: flex;
  justify-content: center;
}

.btn {
  width: 400rpx;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: bold;
  border: none;
}

.btn-primary {
  background: linear-gradient(90deg, #8B4513 0%, #A0522D 100%);
  color: #fff;
}

.btn-secondary {
  background-color: #f0f0f0;
  color: #666;
  border: 2rpx solid #D2B48C;
}

.btn-outline {
  background-color: transparent;
  color: #8B4513;
  border: 2rpx solid #8B4513;
  margin-top: 20rpx;
}

/* 练习结果 */
.result-section {
  padding: 60rpx 10rpx;
}

.result-card {
  background-color: #fff;
  border-radius: 15rpx;
  padding: 60rpx 40rpx;
  text-align: center;
  border: 2rpx solid #D2B48C;
}

.result-icon {
  font-size: 120rpx;
  margin-bottom: 20rpx;
}

.result-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #8B4513;
  margin-bottom: 40rpx;
}

.result-stats {
  display: flex;
  justify-content: space-around;
  margin-bottom: 40rpx;
}

.stat-item {
  text-align: center;
}

.stat-value {
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
}

.stat-item.correct .stat-value {
  color: #4CAF50;
}

.stat-item.wrong .stat-value {
  color: #f44336;
}

.stat-label {
  font-size: 24rpx;
  color: #666;
  margin-top: 8rpx;
}

.result-rate {
  background-color: #faf8f5;
  border-radius: 12rpx;
  padding: 30rpx;
  margin-bottom: 40rpx;
  border: 1rpx solid #D2B48C;
}

.rate-label {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 10rpx;
}

.rate-value {
  font-size: 56rpx;
  font-weight: bold;
  color: #8B4513;
}

.result-buttons {
  display: flex;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.result-buttons .btn {
  width: 280rpx;
}