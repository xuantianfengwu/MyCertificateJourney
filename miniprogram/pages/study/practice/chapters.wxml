<!--pages/study/practice/chapters.wxml-->
<view class="container">
  <!-- 无题库提示 -->
  <view wx:if="{{hasNoQuestionBank}}" class="no-question-bank">
    <view class="no-question-icon">📦</view>
    <view class="no-question-title">该科目暂未开通题库</view>
    <view class="no-question-desc">我们正在努力完善中，敬请期待！</view>
  </view>
  
  <!-- 有题库时显示章节列表 -->
  <view wx:else>
    <view class="header-info">
      <text class="exam-name">{{examName}}</text>
      <text class="question-count">{{totalQuestions}}题</text>
    </view>
    
    <view class="chapter-list">
      <view class="section-title">选择章节</view>
      <view 
        wx:for="{{chapters}}" 
        wx:key="chapterName" 
        class="chapter-item"
        bindtap="selectChapter"
        data-chapter="{{item.chapterName}}"
      >
        <view class="chapter-info">
          <text class="chapter-name">{{item.chapterName}}</text>
          <text class="chapter-count">{{item.questionCount}}道题目</text>
        </view>
        <text class="arrow">→</text>
      </view>
    </view>
  </view>
</view>