/* pages/exam/index.wxss */

.container {
  background-color: #f5f5f5;
  min-height: 100vh;
  padding: 0;
}

/* 授权弹窗 */
.auth-modal {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 9999;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
}

.auth-modal.show {
  opacity: 1;
  visibility: visible;
}

.auth-mask {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-color: rgba(0, 0, 0, 0.5);
}

.auth-content {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  background-color: white;
  border-radius: 20rpx;
  padding: 60rpx 40rpx;
  width: 80%;
  max-width: 500rpx;
  text-align: center;
}

.auth-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.auth-desc {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
  margin-bottom: 40rpx;
}

.auth-btn {
  background-color: #07C160;
  color: white;
  font-size: 30rpx;
  padding: 25rpx 0;
  border-radius: 50rpx;
  margin-bottom: 20rpx;
}

.auth-cancel {
  font-size: 26rpx;
  color: #999;
}

/* 表单样式 */
.form-item {
  margin-bottom: 30rpx;
  text-align: left;
}

.form-label {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 10rpx;
  font-weight: 500;
}

.form-input {
  width: 100%;
  padding: 20rpx;
  border: 2rpx solid #f0f0f0;
  border-radius: 10rpx;
  font-size: 26rpx;
  color: #333;
  background: #f9f9f9;
  box-sizing: border-box;
}

/* 性别选择样式 */
.gender-options {
  display: flex;
  gap: 20rpx;
  margin-bottom: 10rpx;
}

.gender-option {
  flex: 1;
  padding: 20rpx;
  border: 2rpx solid #f0f0f0;
  border-radius: 10rpx;
  text-align: center;
  font-size: 26rpx;
  color: #333;
  background: #f9f9f9;
  transition: all 0.3s;
}

.gender-option.active {
  background: #07C160;
  color: white;
  border-color: #07C160;
}

.gender-tip {
  font-size: 20rpx;
  color: #999;
  margin-top: 5rpx;
}

/* 使用微信信息按钮 */
.wechat-info-btn {
  background-color: #1AAD19;
  color: white;
  font-size: 28rpx;
  padding: 20rpx 0;
  border-radius: 50rpx;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
}

.wechat-info-btn::before {
  content: "💬";
  font-size: 32rpx;
}

/* 头像上传样式 */
.avatar-upload {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.avatar-preview {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 2rpx solid #f0f0f0;
}

.avatar-upload-btn {
  padding: 15rpx 30rpx;
  border: 2rpx solid #07C160;
  border-radius: 50rpx;
  color: #07C160;
  font-size: 24rpx;
  background: #f0fff4;
}

/* 性别选择样式优化 */
.gender-options {
  display: flex;
  gap: 15rpx;
  margin-bottom: 10rpx;
}

.gender-option {
  flex: 1;
  padding: 15rpx;
  border: 2rpx solid #f0f0f0;
  border-radius: 10rpx;
  text-align: center;
  font-size: 24rpx;
  color: #333;
  background: #f9f9f9;
  transition: all 0.3s;
}

/* 提交按钮样式优化 */
.submit-btn {
  background-color: #07C160;
  color: white;
  font-size: 28rpx;
  padding: 18rpx 0;
  border-radius: 50rpx;
  margin-bottom: 20rpx;
  text-align: center;
}

/* 页面内容区域 */
.page-mask {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 9998;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
}

.page-mask.show {
  opacity: 1;
  visibility: visible;
}

.mask-content {
  text-align: center;
}

.mask-button {
  background-color: #07C160;
  color: white;
  font-size: 28rpx;
  padding: 18rpx 50rpx;
  border-radius: 50rpx;
  border: none;
  min-width: 280rpx;
  line-height: 1.4;
  text-align: center;
}

/* 页面内容区域 */
.page-content {
  padding: 0 10rpx;
  margin-top: 20rpx;
  margin-bottom: 20rpx;
  width: 100%;
  box-sizing: border-box;
}

/* 页面标题 */
.page-header {
  text-align: center;
  margin-bottom: 40rpx;
  padding: 30rpx 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.page-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.page-subtitle {
  font-size: 24rpx;
  color: #666;
  text-align: center;
  line-height: 1.4;
  margin-top: 10rpx;
  padding: 0 40rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  max-width: 100%;
  display: inline-block;
}

.link-text {
  color: #07C160;
  text-decoration: underline;
  font-weight: bold;
  display: inline;
  white-space: nowrap;
}

navigator.link-text {
  display: inline;
  white-space: nowrap;
  color: #07C160;
  text-decoration: underline;
  font-weight: bold;
}

/* 考试分类 */
.category-section {
  margin-bottom: 40rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  padding-left: 10rpx;
  border-left: 6rpx solid #07C160;
  flex: 1;
}

.national-list-btn {
  font-size: 24rpx;
  color: #07C160;
  padding: 8rpx 16rpx;
  border: 2rpx solid #07C160;
  border-radius: 20rpx;
  background: #f0fff4;
  transition: all 0.3s;
}

.national-list-btn:hover {
  background: #07C160;
  color: white;
}

/* 国家职业资格名录浮窗 */
.national-list-modal {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 9999;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
}

.national-list-modal.show {
  opacity: 1;
  visibility: visible;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-color: rgba(0, 0, 0, 0.5);
}

.modal-content {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  background-color: white;
  border-radius: 20rpx;
  width: 85%;
  max-width: 600rpx;
  height: 80vh;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 2rpx solid #f0f0f0;
  background: #f9f9f9;
}

.modal-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  flex: 1;
}

.modal-actions {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.modal-website {
  font-size: 22rpx;
  color: #07C160;
  text-decoration: underline;
}

.modal-close {
  font-size: 40rpx;
  color: #999;
  cursor: pointer;
  line-height: 1;
}

/* 目录项样式 */
.directory-item-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  width: 100%;
}

.directory-item-title {
  flex: 1;
  font-size: 26rpx;
  color: #333;
}

.directory-item-arrow {
  font-size: 20rpx;
  color: #666;
  transition: transform 0.3s;
}

.directory-item-arrow.expanded {
  transform: rotate(180deg);
}

.official-category-item {
  background: #f9f9f9;
  border: 2rpx solid #e0e0e0;
}

.official-sub-category-item {
  background: #f5f5f5;
  border: 2rpx solid #e0e0e0;
  margin-left: 20rpx;
}

.sub-directory-list {
  margin-top: 10rpx;
  margin-left: 20rpx;
  animation: slideDown 0.3s ease;
}

@keyframes slideDown {
  from {
    opacity: 0;
    transform: translateY(-10rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.modal-body {
  flex: 1;
  overflow-y: auto;
  padding: 20rpx;
}

/* 目录层级样式 */
.directory-level {
  height: 100%;
}

.directory-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 10rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.directory-back {
  font-size: 24rpx;
  color: #07C160;
  margin-right: 20rpx;
  cursor: pointer;
}

.directory-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  flex: 1;
}

.directory-list {
  display: flex;
  flex-direction: column;
  gap: 15rpx;
}

.directory-item {
  padding: 20rpx;
  border: 2rpx solid #f0f0f0;
  border-radius: 10rpx;
  font-size: 26rpx;
  color: #333;
  background: #f9f9f9;
  transition: all 0.3s;
  cursor: pointer;
}

.directory-item:hover {
  border-color: #07C160;
  color: #07C160;
  background: #f0fff4;
}

.exam-name-item {
  font-size: 24rpx;
  padding: 15rpx;
  line-height: 1.4;
}


.category-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
}

.category-item {
  background: white;
  padding: 15rpx 20rpx;
  border-radius: 15rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
  transition: all 0.3s;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
}

.category-item.active {
  background: #07C160;
  color: white;
}

.category-item:hover {
  transform: translateY(-5rpx);
}

.category-icon {
  font-size: 36rpx;
}

.category-name {
  font-size: 22rpx;
  font-weight: bold;
}

/* 筛选条件 */
.filter-section {
  background: white;
  border-radius: 15rpx;
  padding: 20rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.filter-item {
  margin-bottom: 20rpx;
}

.filter-item:last-child {
  margin-bottom: 0;
}

.filter-label {
  font-size: 24rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 15rpx;
}

.filter-options {
  display: flex;
  flex-wrap: wrap;
  gap: 15rpx;
}

.filter-option {
  padding: 10rpx 20rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 20rpx;
  font-size: 22rpx;
  color: #666;
  transition: all 0.3s;
}

.filter-option.active {
  background: #07C160;
  color: white;
  border-color: #07C160;
}

.filter-option:hover {
  border-color: #07C160;
  color: #07C160;
}

/* 推荐考试列表 */
.exam-section {
  margin-bottom: 40rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  padding-left: 10rpx;
  border-left: 6rpx solid #07C160;
}

.header-right {
  display: flex;
  align-items: center;
  gap: 20rpx;
  flex-wrap: wrap;
  justify-content: flex-end;
}

.questionnaire-link {
  font-size: 22rpx;
  color: #07c160;
  text-decoration: underline;
  white-space: nowrap;
}

.recommend-filter {
  font-size: 22rpx;
  color: #333;
  white-space: nowrap;
}

.checkbox-label {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.checkbox-label checkbox {
  transform: scale(0.8);
}

.sort-option {
  font-size: 22rpx;
  color: #666;
  padding: 10rpx 20rpx;
  border: none;
  border-radius: 20rpx;
  cursor: pointer;
  transition: all 0.3s;
  background: transparent;
  display: flex;
  align-items: center;
  gap: 8rpx;
  white-space: nowrap;
}

/* 推荐等级标签样式 */
.exam-recommend-tag {
  position: absolute;
  top: 0;
  right: 0;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 0 0 0 12rpx;
  color: #fff;
  font-weight: bold;
}

.exam-recommend-tag.unknown {
  background-color: #999;
}

.exam-recommend-tag.stronglyRecommend {
  background-color: #008000; /* 深绿色 */
}

.exam-recommend-tag.recommend {
  background-color: #07c160; /* 浅绿色 */
}

.exam-recommend-tag.notRecommend {
  background-color: #ffc107; /* 黄色 */
  color: #333;
}

.sort-icon {
  font-size: 20rpx;
  line-height: 1;
  margin-top: -2rpx;
}

.sort-option.active {
  color: #07C160;
  font-weight: bold;
}

.sort-option:hover {
  color: #07C160;
  background: rgba(7, 193, 96, 0.1);
}

.exam-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.exam-card {
  background: white;
  border-radius: 15rpx;
  padding: 25rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
  transition: transform 0.3s;
  position: relative;
}

.exam-card:hover {
  transform: translateY(-5rpx);
}

.exam-header {
  margin-bottom: 20rpx;
  position: relative;
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 10rpx;
}

.exam-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  display: inline-block;
  max-width: 60%;
}

.exam-tags {
  display: flex;
  gap: 10rpx;
  align-items: center;
  margin-bottom: 0;
  flex-wrap: wrap;
}

.tag {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
}

.tag.tax {
  background: #E8F5E8;
  color: #07C160;
}

.tag.level {
  background: #E3F2FD;
  color: #2196F3;
}

.tag.pass-rate {
  background: #E8F5E8;
  color: #07C160;
}

.tag.exam-fee {
  background: #E3F2FD;
  color: #2196F3;
}

.exam-fit {
  position: absolute;
  top: 0;
  right: 0;
  font-size: 20rpx;
  padding: 6rpx 12rpx;
  border-radius: 12rpx;
  font-weight: bold;
}

.exam-fit.stronglyRecommend {
  background: #008000;
  color: #fff;
}

.exam-fit.recommend {
  background: #07C160;
  color: #fff;
}

.exam-fit.notRecommend {
  background: #FFC107;
  color: #333;
}

.exam-fit.unknown {
  background: #F5F5F5;
  color: #9E9E9E;
}

.exam-info {
  display: flex;
  justify-content: space-between;
  margin-bottom: 15rpx;
  padding-bottom: 15rpx;
  border-bottom: 1rpx solid #f0f0f0;
  flex-wrap: wrap;
}

.info-item {
  flex: 1;
  min-width: 20%;
  text-align: center;
  margin-bottom: 10rpx;
}

.info-label {
  font-size: 20rpx;
  color: #666;
  margin-bottom: 5rpx;
}

.info-value {
  font-size: 24rpx;
  font-weight: bold;
  color: #333;
}

.exam-desc {
  font-size: 22rpx;
  color: #666;
  line-height: 1.4;
  margin-bottom: 20rpx;
}

.exam-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-wrap: wrap;
  gap: 10rpx;
}

.exam-footer-tags {
  display: flex;
  gap: 10rpx;
  align-items: center;
  flex: 1;
  justify-content: flex-start;
  margin-left: 10rpx;
}

.exam-footer-right {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.exam-apply {
  font-size: 20rpx;
  padding: 8rpx 16rpx;
  border-radius: 12rpx;
  background: #FFF3E0;
  color: #FF9800;
}

.exam-arrow {
  width: 30rpx;
  height: 30rpx;
}

/* 分页组件 */
.pagination {
  display: flex;
  justify-content: center;
  align-items: center;
  margin-top: 30rpx;
  margin-bottom: 30rpx;
  height: 60rpx;
  background-color: #f5f5f5;
  border-radius: 30rpx;
  padding: 0 20rpx;
}

.pagination-btn {
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #333;
  cursor: pointer;
}

.pagination-numbers {
  display: flex;
  margin: 0 20rpx;
}

.pagination-number {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  margin: 0 5rpx;
  font-size: 28rpx;
  color: #666;
  border-radius: 20rpx;
  cursor: pointer;
}

.pagination-number.active {
  background-color: #1989fa;
  color: white;
}

.pagination-ellipsis {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  margin: 0 5rpx;
  font-size: 28rpx;
  color: #666;
}
