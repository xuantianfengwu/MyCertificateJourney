/* pages/exam/questionnaire/questionnaire.wxss */
.container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.subtitle {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 30rpx;
  text-align: center;
}

.question {
  margin-bottom: 20rpx;
}

.question-title {
  font-size: 24rpx;
  color: #333;
  margin-bottom: 8rpx;
  display: block;
  font-weight: bold;
}

.input {
  border: 1rpx solid #ddd;
  border-radius: 8rpx;
  padding: 16rpx;
  font-size: 22rpx;
  width: 100%;
  box-sizing: border-box;
}

.textarea {
  border: 1rpx solid #ddd;
  border-radius: 8rpx;
  padding: 16rpx;
  font-size: 22rpx;
  width: 100%;
  box-sizing: border-box;
  min-height: 120rpx; /* 2行文本高度 */
  resize: none;
}

.button-area {
  display: flex;
  justify-content: space-between;
  margin-top: 30rpx;
  margin-bottom: 30rpx;
}

.reset-button, .submit-button {
  width: 48%;
  height: 80rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
}

.reset-button {
  background-color: #fff;
  border: 1rpx solid #ddd;
  color: #666;
}

.submit-button {
  background-color: #07c160;
  color: #fff;
}

.required {
  color: #ff4d4f;
  margin-left: 8rpx;
}

/* 响应式调整 */
@media (max-width: 375px) {
  .container {
    padding: 16rpx;
  }
  
  .section {
    padding: 20rpx;
  }
  
  .title {
    font-size: 28rpx;
  }
  
  .section-title {
    font-size: 24rpx;
  }
  
  .question-title {
    font-size: 22rpx;
  }
  
  .radio-item, .checkbox-item {
    font-size: 20rpx;
  }
  
  .input {
    font-size: 20rpx;
    padding: 14rpx;
  }
  
  .button-area {
    flex-direction: column;
  }
  
  .reset-button, .submit-button {
    width: 100%;
    margin-bottom: 12rpx;
  }
}