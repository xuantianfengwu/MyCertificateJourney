/* components/guide-mask/guide-mask.wxss */
.guide-mask {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 9998;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
}

.guide-mask.show {
  opacity: 1;
  visibility: visible;
}

.mask-content {
  text-align: center;
}

.mask-button {
  background-color: #07C160;
  color: white;
  font-size: 28rpx;
  padding: 18rpx 50rpx;
  border-radius: 50rpx;
  border: none;
  min-width: 280rpx;
  line-height: 1.4;
  text-align: center;
}
